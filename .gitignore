# Test audio files (large, don't commit)
/tests/**/*.m4a

# Output subfiles from batch processing
/tests/**/*_subfile/

# Second brain exports
/second_brain_export/

# Python
__pycache__/
*.pyc
*.pyo

# Logs
logs/

# OS
.DS_Store

# Test complete outputs and versioned re-runs
/tests/test_complete/
/tests/**/*_subfile[*/

# Impeccable config (local tooling)
.impeccable/

# Keep folder structure
!tests/**/.gitkeep
